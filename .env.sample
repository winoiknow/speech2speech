# ── Server authentication ────────────────────────────────────────────────────
# Bearer token that incoming WebSocket clients must supply.
# Clients connect with: Authorization: Bearer <your-key-here>
# Leave empty (or unset) to disable authentication.
SERVER_API_KEY=

# ── STT — Whisper-compatible /v1/audio/transcriptions ────────────────────────
STT_OPENAI_BASE_URL=http://192.168.1.10:8000
STT_OPENAI_API_KEY=sk-unused
STT_OPENAI_MODEL=Systran/faster-whisper-large-v3
STT_OPENAI_LANGUAGE=en

# ── TTS source toggle ────────────────────────────────────────────────────────
# "openai-remote" (default) = F5-TTS /stream endpoint below.
# "elevenlabs"             = ElevenLabs cloud TTS (for sites without an on-prem
#                            TTS server); fill in the ELEVENLABS_* block below.
# "minimax"                = MiniMax T2A v2 WebSocket TTS (streaming pcm@16k,
#                            voice cloning); fill in the MINIMAX_* block below.
TTS_SOURCE=openai-remote

# ── TTS — openai-remote: F5-TTS /v1/audio/speech/stream ──────────────────────
TTS_OPENAI_BASE_URL=http://192.168.1.10:8880
TTS_OPENAI_API_KEY=sk-unused
TTS_OPENAI_VOICE=default
TTS_OPENAI_MODEL=tts-1

# ── TTS — elevenlabs (used only when TTS_SOURCE=elevenlabs) ───────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# pcm_16000 = best quality, no resample, but PCM streaming needs a paid tier.
# ulaw_8000 = works on free tier (decoded + upsampled to 16 kHz). mp3 unsupported.
ELEVENLABS_OUTPUT_FORMAT=pcm_16000
# Optional voice_settings:
# ELEVENLABS_STABILITY=0.5
# ELEVENLABS_SIMILARITY_BOOST=0.75

# ── TTS — minimax (used only when TTS_SOURCE=minimax) ─────────────────────────
# WebSocket streaming, pcm@16k (no resample), ~0.5s cold / ~0.27s warm TTFB,
# supports voice cloning. The WS path needs a paid account (not free tier).
MINIMAX_API_KEY=
# A cloned voice id, or a system voice for testing (e.g. English_expressive_narrator)
MINIMAX_VOICE_ID=
MINIMAX_MODEL=speech-02-turbo
# Use the api.minimaxi.com host for the mainland endpoint.
MINIMAX_WS_URL=wss://api.minimax.io/ws/v1/t2a_v2
# Optional, only if your account requires it:
# MINIMAX_GROUP_ID=

# ── LLM — OpenAI-compatible /v1/responses or /v1/chat/completions ────────────
LLM_BASE_URL=http://192.168.1.10:7860/v1
LLM_API_KEY=sk-unused
LLM_MODEL=hermes-agent
# Sentences buffered before the first TTS batch fires. Lower = lower
# time-to-first-audio (TTS starts sooner) at the cost of more, shorter TTS calls.
# A/B 1 vs 2 vs 3 for the latency test. Default 3.
STREAM_BATCH_SENTENCES=3

# ── General ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# DEBUG_MODE=on re-enables verbose diagnostics (VAD heartbeat, audio-drop and
# TTS-timing logs). Leave off/unset for clean production logs.
DEBUG_MODE=off

# ── Acoustic echo cancellation (input path) ──────────────────────────────────
# Subtract the agent's own TTS from the caller's mic before the VAD, so the VAD
# stops tripping on echo (phantom barge-ins / deaf-during-playback). Needs the
# full-duplex client to actually deliver mic during playback. Fail-safe if the
# speexdsp dep is missing. AEC_FILTER_LENGTH_MS must cover the echo round-trip
# delay (tens of ms on LAN/browser; much larger with a client jitter buffer).
AEC_ENABLED=0
# Backend: aec3 (WebRTC AEC3, default — delay-estimating, handles the cross-clock
# networked echo) or speex (libspeexdsp, adaptive filter only).
AEC_BACKEND=aec3
# speex only: filter tail length in ms (must cover the echo round-trip delay).
AEC_FILTER_LENGTH_MS=250
# Reject mic chunks whose RAW int16 RMS is below this before the VAD decides.
# Keyed on raw mic energy (not the AEC-cleaned signal): AEC suppresses a real
# double-talk barge-in down to the echo-residual level, so only the raw mic
# separates the user's voice (~140-2000+) from speaker echo (~6-40). Kills
# phantom barge-ins on echo leaks. Tune with the DEBUG_MODE 'maxpass' heartbeat
# (loudest raw chunk that cleared the gate) — set above echo maxpass, below your
# speech level. Lower if a real barge-in is missed; raise if phantoms persist.
# 0 disables.
VAD_INPUT_RMS_GATE=100
# FAR-AWARE gate: while the agent is SPEAKING, gate on the AEC residual at this
# threshold instead of raw mic energy. At higher speaker volume raw echo exceeds
# the raw gate, but AEC cancels echo to a low residual while your voice survives
# (it isn't in the far reference) — so during playback, echo (low residual) is
# rejected and a real barge-in (high residual) passes. Tune via the DEBUG_MODE
# 'maxpass' heartbeat during an agent turn (it shows residual levels then). 0
# disables far gating (revert to raw gate always). NOTE: echo residual and a real
# barge-in's residual can overlap, so there's no perfect value — bias HIGHER to
# avoid phantom barge-ins cancelling the agent (more disruptive than re-saying a
# barge-in). Watch the 'far=N maxpass=M' heartbeat during an agent turn: M is the
# echo-residual ceiling; set this above it.
VAD_INPUT_RMS_GATE_FAR=400
# Sustained-energy filter for the far gate: while the agent speaks, a chunk only
# passes if >= MIN of the last WINDOW chunks (~32ms each) cleared the residual
# gate. Echo-residual leaks are sparse transient spikes (a level gate can't tell
# a 533 echo spike from a 533 speech onset); real speech is dense. This rejects
# the transient and passes sustained speech — the volume-independent half of the
# fix. Higher MIN = stricter (fewer phantoms, but a very brief barge-in may be
# missed). Observed: phantom ~5/32 chunks vs real barge-in ~8/9.
VAD_FAR_SUSTAIN_MIN=6
VAD_FAR_SUSTAIN_WINDOW=12

# ── End-of-turn detection ─────────────────────────────────────────────────────
# "vad" = end the turn after a fixed silence (the client's silence_duration_ms /
# VAD timer). "smart_turn" = Pipecat Smart Turn v3, a semantic endpointing model
# (Whisper-tiny + linear head, int8 ONNX, ~12ms CPU) that reads prosody/content
# to tell "I'm done" from "I'm just pausing" — no more mid-thought cutoffs.
# silero finds the pause; the model makes the real end-of-turn call.
TURN_DETECTION=vad
# smart_turn only: silence (ms) before asking the model. Short = snappy turns.
TURN_MIN_SILENCE_MS=300
# smart_turn only: hard ceiling (s) on one turn so it can never hang.
TURN_MAX_S=30
# smart_turn only: completeness probability threshold (0-1). Higher = wait for
# stronger end-of-turn evidence (fewer early cutoffs, a bit more latency).
SMART_TURN_THRESHOLD=0.5
# smart_turn only: DON'T-HANG NET (not a turn timer). After an "incomplete"
# verdict the turn waits for more speech; if the user instead goes silent this
# long (ms), finalize anyway so the turn can never hang. We trust Smart Turn's
# "incomplete" for this whole window, so it MUST sit above a natural mid-sentence
# thinking pause (~1.5-2.5s) — too low and it cuts you off, defeating the point.
TURN_HOLD_GRACE_MS=3000
# smart_turn only: path to the ONNX model baked into the image.
SMART_TURN_MODEL_PATH=/app/models/smart-turn-v3.2-cpu.onnx
# smart_turn only: explicit ONNX intra-op thread count. Setting this disables
# onnxruntime's CPU-affinity pinning, which fails (EINVAL) under a container
# cpuset and spams pthread_setaffinity_np errors. Small is fine (runs per-pause).
SMART_TURN_NUM_THREADS=2

# ── Speaker identification (off by default) ───────────────────────────────────
# When enabled, s2s fires the speaker-id service's /v1/identify CONCURRENTLY with
# transcribe (overlapping round-trips → ~0 added latency, reusing the raw user
# audio) and, on a confident `known` match, prefixes the dialogue with the tag
# below. unknown/ambiguous get no prefix. Any timeout/error → unknown; the turn
# never blocks. The consumer's system prompt (AVA) decides what a tag means.
# Run the speaker-id service first (see docker-compose --profile speaker-id, or
# its own repo at ~/workspace/diarization/speaker-id) and enroll a voice.
SPEAKER_ID_ENABLED=0
SPEAKER_ID_BASE_URL=http://speaker-id:9100
SPEAKER_ID_API_KEY=
# Hard timeout (s) on the identify call; on timeout → unknown, no retry.
SPEAKER_ID_TIMEOUT=0.8
# Inline tag on a confident match. {name} and {speaker_id} available; empty = off.
SPEAKER_ID_LABEL_FORMAT=[{name}]
# Phase 4 (Tier 2): async conference diarization, OFF the hot path and OFF by
# default. Separate from recognition above — when on, /v1/diarize runs after the
# turn and drives a corrective event (idempotent, revision-versioned) that
# replaces span labels by item_id. Dropped-safe: a consumer that ignores it keeps
# the Tier-1 label. Needs the diarizer model set on the speaker-id service.
SPEAKER_DIARIZE_ENABLED=0
SPEAKER_DIARIZE_TIMEOUT=5.0

# ── Multi-session (remote profile only) ──────────────────────────────────────
# Concurrent realtime sessions this one process accepts. 1 = exactly today's
# single-session behavior. Raise deliberately after load-testing the shared
# STT/TTS/LLM endpoints (see LATENCY.md §7 — the load test wants this >= the
# largest concurrency you drive, e.g. 8). FORCED to 1 with a warning if any of
# STT/TTS/LLM is an in-process local model — multi-session needs the model behind
# a serving endpoint (the openai-remote / responses-api handlers above).
S2S_MAX_SESSIONS=1
# Reap a session this many seconds after its last inbound client traffic. 0 (the
# default) never reaps — warm connections (smart speakers) hold idle sessions
# open indefinitely. Set a value to reclaim abandoned sessions.
S2S_IDLE_TIMEOUT_S=0
# How often (s) the per-session send loop checks its handler threads are alive; a
# crashed handler fails that session with a server_error instead of serving dead
# audio. 0 disables. Default 2.
S2S_THREAD_SUPERVISOR_S=2
# Per-service caps on concurrent in-flight requests across all sessions, so N
# sessions queue fairly behind a busy endpoint instead of melting it. 0 = no cap
# (today's behavior). Tune alongside the external service's own concurrency
# (Whisper batch slots, F5 instances, Hermes workers) — see LATENCY.md §7.3.
STT_MAX_CONCURRENCY=0
TTS_MAX_CONCURRENCY=0
LLM_MAX_CONCURRENCY=0
