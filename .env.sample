# ── Server authentication ────────────────────────────────────────────────────
# Bearer token that incoming WebSocket clients must supply.
# Clients connect with: Authorization: Bearer <your-key-here>
# Leave empty (or unset) to disable authentication.
SERVER_API_KEY=

# ── STT — Whisper-compatible /v1/audio/transcriptions ────────────────────────
STT_OPENAI_BASE_URL=http://192.168.1.10:8000
STT_OPENAI_API_KEY=sk-unused
STT_OPENAI_MODEL=Systran/faster-whisper-large-v3
STT_OPENAI_LANGUAGE=en

# ── TTS — F5-TTS /v1/audio/speech/stream ─────────────────────────────────────
TTS_OPENAI_BASE_URL=http://192.168.1.10:8880
TTS_OPENAI_API_KEY=sk-unused
TTS_OPENAI_VOICE=default

# ── LLM — OpenAI-compatible /v1/responses or /v1/chat/completions ────────────
LLM_BASE_URL=http://192.168.1.10:7860/v1
LLM_API_KEY=sk-unused

# ── General ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
