# speaker-id service — copy to .env and adjust. docker compose auto-loads .env
# from this directory, so the values below feed docker-compose.yml's ${...} refs.

# ── Recognition threshold (the main tuning knob) ──────────────────────────────
# Cosine cutoff for a "known" decision. The default 0.65 is CONSERVATIVE — it was
# set from clean ~5-10s enrollment clips. Live conversational turns are shorter
# (1-3s) and on the runtime channel, so genuine scores run LOWER and good turns
# can fall under 0.65 → unknown → no tag (fewer recognized turns).
#
# There is large headroom: an impostor scored ~0.17, so 0.5 still sits far above
# any non-match. Lower toward 0.45-0.55 for better per-turn recall. MEASURE FIRST:
#   docker logs <speaker-id-container> | grep identify     # see the per-turn score
# then set the threshold just under your genuine conversational scores.
# (This raises recall per turn — it does NOT latch identity; every turn is still
#  judged independently, which is what diarization needs.)
SIMILARITY_THRESHOLD=0.5

# top-1 minus top-2 below this → "ambiguous" (no forced label). Only bites with
# multiple enrolled speakers; harmless with one.
AMBIGUOUS_MARGIN=0.08

# ── Embedding model ───────────────────────────────────────────────────────────
# ECAPA-TDNN (non-gated, baked into the image). Set "stub" for a torch-free run.
EMBEDDING_MODEL=speechbrain/spkrec-ecapa-voxceleb
EMBEDDING_DEVICE=cpu
# EMBEDDING_SAVEDIR=/models/ecapa        # baked in the image; usually leave as-is
# (gated-model token? see HF_TOKEN in the Diarization block below)

# ── Store ─────────────────────────────────────────────────────────────────────
STORE_BACKEND=sqlite
STORE_PATH=/data/speakers.db            # persisted via the speaker_data volume

# ── Enrollment quality gate ───────────────────────────────────────────────────
# Reject enrollment clips shorter than this many seconds of speech (after trim).
MIN_SAMPLE_SECONDS=2.0

# ── Diarization (Phase 4, Tier 2 — off the s2s hot path) ──────────────────────
# The default "stub" returns the whole clip as ONE span (torch-free) — /v1/diarize
# then behaves like /v1/identify in segment shape. To actually split mixed audio
# into per-speaker spans you need BOTH:
#   1. INSTALL_PYANNOTE=1   → bakes pyannote.audio into the image (BUILD-time; heavy).
#                             Changing this requires a rebuild: docker compose build
#                             (or `up -d --build`), not just `up -d`.
#   2. DIARIZATION_MODEL=pyannote/speaker-diarization-community-1   + an HF_TOKEN.
# With INSTALL_PYANNOTE=0 the pyannote model isn't in the image, so a pyannote
# DIARIZATION_MODEL falls back to the fail-safe (empty segments) with a warning.
INSTALL_PYANNOTE=0
DIARIZATION_MODEL=stub
DIARIZATION_DEVICE=cpu
# HuggingFace access token — REQUIRED only for a gated model (the pyannote diarizer
# above, or a gated pyannote embedder). Leave blank for the stub / ECAPA defaults.
# Get one at https://huggingface.co/settings/tokens (read scope) AND accept the
# model's gated-access terms on its HF page, or from_pretrained returns 401/None.
# Treat it as a secret — .env is gitignored; never commit a real token.
HF_TOKEN=
# Ephemeral per-call labels (S1, S2…) for unenrolled voices are grouped by the
# diarizer's OWN speaker labels (pyannote clusters internally), so there's no
# separate clustering knob — one label per distinct unenrolled speaker.
MIN_SEGMENT_SECONDS=0.4     # skip spans shorter than this (too brief to embed reliably)
MAX_DIARIZE_SEGMENTS=64     # cap spans embedded per clip (budget guard)

# ── Admin access gate (Phase 5, Workstream A) ─────────────────────────────────
# The /enroll console + speaker admin APIs are UNAUTHENTICATED by default (trusted
# network only). Configure EITHER path below to lock them down; set both for SSO
# with a local fallback. With neither set, the service logs a loud warning.
#
# Local admin (bootstrap token) — first-run + SSO-down fallback. Use a long random
# value; it's both the login-page password and an API bearer (Authorization: Bearer).
LOCAL_ADMIN_TOKEN=
# Signed-cookie session secret (set a stable random value so logins survive restart).
SESSION_SECRET=
# In-app OIDC SSO (authlib). Redirect URI must be https://<host>/auth/oidc/callback.
OIDC_ENABLED=0
OIDC_DISCOVERY_URL=        # e.g. https://idp.example.com/.well-known/openid-configuration
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Who may admin. Set at least one or ANY IdP-authenticated user becomes admin.
OIDC_ALLOWED_EMAILS=       # comma-separated, e.g. eric@anteon.group,ops@anteon.group
OIDC_ALLOWED_DOMAIN=       # e.g. anteon.group (any email @that domain)
# Machine data plane (/v1/identify, /v1/diarize). If set, callers (s2s) must send
# Authorization: Bearer <this>. Match it to s2s SPEAKER_ID_API_KEY. Empty = open.
SERVICE_API_KEY=

# ── Email-invite self-enrollment (Phase 5B) ───────────────────────────────────
# An admin issues an invite (name + email); the invitee opens a personal link
# (/enroll/invite?token=…) — token-gated, NO login (OIDC-immune) — to consent,
# record/upload, and self-test. The token is a TIME-WINDOW credential: reusable
# until it expires or is revoked (not single-use). Only a SHA-256 hash is stored.
INVITE_TTL_HOURS=72
# External URL used to build the link in the email (set this behind a proxy so the
# link host is right). Falls back to the request's base URL if empty.
PUBLIC_BASE_URL=          # e.g. https://speaker-id.example.com
# On-site SMTP. With SMTP_HOST empty the invite email is LOGGED, not sent (a stub
# for testing the flow); set these to actually send via your relay.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=speaker-id@localhost
SMTP_STARTTLS=1
# NOTE: TLS is terminated by your reverse proxy (no sidecar here). OIDC needs https
# redirect URIs, and https is also what lets the enroll page capture the mic.

# ── General ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
